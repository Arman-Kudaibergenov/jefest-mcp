# Task profiles: which MCP servers to load for each task type
mcp_profiles:
  bsl-coding:
    description: "BSL code writing/editing"
    servers: [rlm-toolkit, 1c-help, 1c-templates, 1c-syntax-checker, 1c-code-checker]
  form-edit:
    description: "Form.xml editing"
    servers: [rlm-toolkit, 1c-forms, 1c-syntax-checker]
  ui-test:
    description: "Playwright UI testing"
    servers: [rlm-toolkit, playwright, 1c-ai-debug]
  code-search:
    description: "Code search and analysis"
    servers: [rlm-toolkit, 1c-codemetadata-kaf]
  data-ops:
    description: "Database operations via AI Debug"
    servers: [rlm-toolkit, 1c-ai-debug]
  full-1c:
    description: "All 1C tools (for complex tasks)"
    servers: [rlm-toolkit, 1c-help, 1c-ssl, 1c-templates, 1c-syntax-checker, 1c-code-checker, 1c-forms]
  minimal:
    description: "Only RLM (for non-1C tasks)"
    servers: [rlm-toolkit]

